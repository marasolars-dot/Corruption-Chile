# ===========================================
# Graphiques attractifs pour dataset corruption
# ===========================================

# 0. Packages ---------------------------------------------------------------

library(tidyverse)
library(ggthemes)
library(scales)
library(ggrepel)       # pour labels non chevauchants
library(treemapify)
install.packages("wordcloud2")
library(wordcloud2)
install.packages("ggraph")
library(ggraph)
library(igraph)

# Assurez-vous que votre dataframe s'appelle "corrupcion"
# Corrigeons quelques colonnes si nécessaire
corrupcion$monto <- as.numeric(corrupcion$monto)
corrupcion$año <- as.numeric(corrupcion$año)

# ===========================================
# 1️⃣ Histogramme et Boxplot des montants
# ===========================================
# Histogramme log pour bien visualiser les grandes valeurs
ggplot(corrupcion, aes(x = monto)) +
  geom_histogram(fill = "#FF6F61", color = "white", bins = 30) +
  scale_x_log10(labels = scales::dollar_format(prefix = "$")) +
  labs(title = "Distribution des montants de corruption",
       x = "Montant (log10)", y = "Nombre de cas") +
  theme_minimal() +
  theme(plot.title = element_text(face = "bold", size = 14))

# Boxplot par secteur
ggplot(corrupcion, aes(x = sector, y = monto, fill = sector)) +
  geom_boxplot(alpha = 0.7) +
  scale_y_log10(labels = scales::dollar_format(prefix = "$")) +
  labs(title = "Montants de corruption par secteur", x = "Secteur", y = "Montant (log10)") +
  theme_light() +
  theme(legend.position = "none", plot.title = element_text(face = "bold"))

# ===========================================
# 2️⃣ Évolution temporelle
# ===========================================
# Nombre de cas par année
ggplot(corrupcion, aes(x = año)) +
  geom_bar(fill = "#4C72B0") +
  scale_x_continuous(breaks = seq(min(corrupcion$año, na.rm=TRUE), max(corrupcion$año, na.rm=TRUE), 2)) +
  labs(title = "Nombre d'affaires de corruption par année", x = "Année", y = "Nombre de cas") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

# Montant total par année
corrupcion %>% 
  group_by(año) %>% 
  summarise(total_monto = sum(monto, na.rm=TRUE)) %>%
  ggplot(aes(x = año, y = total_monto)) +
  geom_col(fill = "#F28E2B") +
  scale_y_continuous(labels = scales::dollar_format(prefix = "$")) +
  labs(title = "Montant total de corruption par année", x = "Année", y = "Montant total") +
  theme_minimal()

# ===========================================
# 3️⃣ Top responsables
# ===========================================
top_responsables <- corrupcion %>% 
  group_by(responsable) %>% 
  summarise(total_monto = sum(monto, na.rm = TRUE)) %>%
  arrange(desc(total_monto)) %>%
  slice(1:10)

ggplot(top_responsables, aes(x = reorder(responsable, total_monto), y = total_monto, fill = total_monto)) +
  geom_col() +
  coord_flip() +
  scale_fill_gradient(low = "#FFDDC1", high = "#FF6F61") +
  scale_y_continuous(labels = scales::dollar_format(prefix = "$")) +
  labs(title = "Top 10 responsables par montant total", x = "Responsable", y = "Montant total") +
  theme_minimal()

# ===========================================
# 4️⃣ Secteur et Parti
# ===========================================
# Treemap montant total par secteur
corrupcion %>% 
  group_by(sector) %>%
  summarise(total_monto = sum(monto, na.rm = TRUE)) %>%
  ggplot(aes(area = total_monto, fill = sector, label = sector)) +
  geom_treemap() +
  geom_treemap_text(color = "white", place = "centre", grow = TRUE) +
  scale_fill_brewer(palette = "Set3") +
  labs(title = "Montant total de corruption par secteur") +
  theme(legend.position = "none")

# Heatmap secteur × parti
corrupcion %>% 
  group_by(sector, partido) %>% 
  summarise(total_monto = sum(monto, na.rm=TRUE)) %>% 
  ggplot(aes(x = partido, y = sector, fill = total_monto)) +
  geom_tile(color = "white") +
  scale_fill_gradient(low = "white", high = "#D62728", labels = scales::dollar_format(prefix = "$")) +
  labs(title = "Montant total de corruption par secteur et parti", x = "Parti", y = "Secteur") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

# ===========================================
# 5️⃣ Géographie (communes)
# ===========================================
# Top 10 communes par montant
top_comunas <- corrupcion %>% 
  group_by(comuna) %>% 
  summarise(total_monto = sum(monto, na.rm=TRUE)) %>% 
  arrange(desc(total_monto)) %>% 
  slice(1:10)

ggplot(top_comunas, aes(x = reorder(comuna, total_monto), y = total_monto, fill = total_monto)) +
  geom_col() +
  coord_flip() +
  scale_fill_gradient(low="#A1C9F4", high="#4C72B0") +
  scale_y_continuous(labels = scales::dollar_format(prefix="$")) +
  labs(title="Top 10 communes par montant total de corruption", x="Commune", y="Montant total") +
  theme_minimal() +
  theme(legend.position="none")

# ===========================================
# 6️⃣ Wordcloud des délits
# ===========================================
# Séparer les délits
library(stringr)
delitos <- str_split(corrupcion$delitos, ",") %>% unlist() %>% str_trim()
delitos_freq <- table(delitos) %>% as.data.frame()
colnames(delitos_freq) <- c("word", "freq")

wordcloud2(delitos_freq, size = 0.7, color='random-light', backgroundColor = "#333333")

# ===========================================
# 7️⃣ État / condamnation
# ===========================================
corrupcion %>% 
  group_by(estado, condena) %>% 
  summarise(n = n()) %>% 
  ggplot(aes(x = estado, y = n, fill = condena)) +
  geom_bar(stat="identity", position="stack") +
  labs(title="État vs Condamnation", x="État", y="Nombre de cas", fill="Condamnation") +
  theme_minimal()

# ===========================================
# 8️⃣ Scatter plot avec taille par montant et couleur par parti
# ===========================================
ggplot(corrupcion, aes(x = año, y = monto, size = monto, color = partido)) +
  geom_point(alpha = 0.7) +
  scale_y_log10(labels = scales::dollar_format(prefix="$")) +
  scale_size(range = c(3, 12)) +
  labs(title="Montants par année et parti", x="Année", y="Montant (log10)", size="Montant", color="Parti") +
  theme_light()

# ===========================================
# 9️⃣ Réseau des responsables et bénéficiaires
# ===========================================
# On ne fait qu’un exemple simple pour illustrer
edges <- corrupcion %>% 
  filter(!is.na(responsable) & !is.na(beneficiado)) %>%
  select(responsable, beneficiado) %>%
  distinct()

g <- graph_from_data_frame(edges, directed = TRUE)

ggraph(g, layout = "fr") +
  geom_edge_link(alpha=0.5, arrow = arrow(length = unit(4, 'mm')), end_cap = circle(3, 'mm')) +
  geom_node_point(size = 5, color = "#FF6F61") +
  geom_node_text(aes(label=name), repel=TRUE, size=3) +
  labs(title="Réseau Responsable → Bénéficiaire") +
  theme_void()



