# Histogramme log pour bien visualiser les grandes valeurs
ggplot(corrupcion, aes(x = monto)) +
  geom_histogram(fill = "#FF6F61", color = "white", bins = 30) +
  scale_x_log10(labels = scales::dollar_format(prefix = "$")) +
  labs(title = "Distribution des montants de corruption",
       x = "Montant (log10)", y = "Nombre de cas") +
  theme_minimal() +
  theme(plot.title = element_text(face = "bold", size = 14))

# Boxplot par secteur
ggplot(corrupcion, aes(x = sector, y = monto, fill = sector)) +
  geom_boxplot(alpha = 0.7) +
  scale_y_log10(labels = scales::dollar_format(prefix = "$")) +
  labs(title = "Montants de corruption par secteur", x = "Secteur", y = "Montant (log10)") +
  theme_light() +
  theme(legend.position = "none", plot.title = element_text(face = "bold"))

