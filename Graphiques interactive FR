# 4. CALCUL DES MONTANTS EN EUROS
# ─────────────────────────────────────────────
cas <- cas %>%
  mutate(
    montant_eur = montant_clp / TAUX_CLP_EUR,
    montant_eur_fmt = case_when(
      is.na(montant_eur)          ~ "Inconnu",
      montant_eur >= 1e9          ~ paste0(round(montant_eur/1e9, 2), " Md €"),
      montant_eur >= 1e6          ~ paste0(round(montant_eur/1e6, 2), " M€"),
      montant_eur >= 1e3          ~ paste0(round(montant_eur/1e3), " k€"),
      TRUE                        ~ paste0(round(montant_eur), " €")
    ),
    montant_clp_fmt = case_when(
      is.na(montant_clp) ~ "Inconnu",
      TRUE ~ paste0(format(round(montant_clp/1e6), big.mark=" "), " M CLP")
    )
  )


# ─────────────────────────────────────────────
# 5. JOINTURE AVEC LES COORDONNÉES + JITTER
# ─────────────────────────────────────────────
cas_geo <- cas %>%
  filter(!is.na(commune)) %>%
  left_join(coords, by = "commune") %>%
  filter(!is.na(lat))

# Jitter pour éviter la superposition des marqueurs dans la même commune
set.seed(42)
cas_geo <- cas_geo %>%
  group_by(commune) %>%
  mutate(
    n_commune = n(),
    idx       = row_number(),
    angle     = (idx / n_commune) * 2 * pi,
    jitter    = ifelse(n_commune > 1, 0.02 + idx * 0.008, 0),
    lat_j     = lat + sin(angle) * jitter,
    lng_j     = lng + cos(angle) * jitter
  ) %>%
  ungroup()


