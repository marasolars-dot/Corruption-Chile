# 6. COULEURS PAR BORD POLITIQUE
# ─────────────────────────────────────────────
couleur_bord <- function(bord) {
  dplyr::case_when(
    bord == "Droite"  ~ "#e74c3c",
    bord == "Gauche"  ~ "#3498db",
    bord == "Centre"  ~ "#f39c12",
    bord == "Aucun"   ~ "#9b59b6",
    TRUE              ~ "#7f8c8d"
  )
}

cas_geo <- cas_geo %>%
  mutate(couleur = couleur_bord(bord))


# ─────────────────────────────────────────────
# 7. RAYON DES CERCLES (proportionnel au montant)
# ─────────────────────────────────────────────
rayon_cercle <- function(eur) {
  dplyr::case_when(
    is.na(eur)        ~ 6,
    eur < 50000       ~ 6,
    eur < 500000      ~ 10,
    eur < 2000000     ~ 16,
    eur < 15000000    ~ 24,
    eur < 50000000    ~ 36,
    TRUE              ~ 48
  )
}

cas_geo <- cas_geo %>%
  mutate(rayon = rayon_cercle(montant_eur))


