    data        = cas_geo %>% filter(poste == "Fondation"),
    lng         = ~lng_j, lat = ~lat_j,
    radius      = ~rayon,
    fillColor   = ~couleur, color = "#ffffff", weight = 2.5, fillOpacity = 0.9,
    popup       = ~popup_html,
    group       = "Fondations",
    label       = ~paste0(affaire, " (", montant_eur_fmt, ")")
  ) %>%

  # ── Couche : Mairies ──────────────────────────────────────────────
  addCircleMarkers(
    data        = cas_geo %>% filter(poste == "Maire"),
    lng         = ~lng_j, lat = ~lat_j,
    radius      = ~rayon,
    fillColor   = ~couleur, color = "#ffaa00", weight = 2, fillOpacity = 0.85,
    popup       = ~popup_html,
    group       = "Mairies",
    label       = ~paste0(affaire, " (", montant_eur_fmt, ")")
  ) %>%

  # ── Couche : FFAA / Police ────────────────────────────────────────
  addCircleMarkers(
    data        = cas_geo %>% filter(poste %in% c("Carabiniers","Armée","Police judiciaire")),
    lng         = ~lng_j, lat = ~lat_j,
    radius      = ~rayon,
    fillColor   = "#9b59b6", color = "white", weight = 2, fillOpacity = 0.85,
