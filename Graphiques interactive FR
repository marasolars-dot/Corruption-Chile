carte <- leaflet(cas_geo,
                 options = leafletOptions(zoomControl = TRUE)) %>%

  # Fond de carte sombre CartoDB
  addProviderTiles(
    providers$CartoDB.DarkMatter,
    options = tileOptions(opacity = 1)
  ) %>%

  # Centrage initial sur le Chili
  setView(lng = -70.6, lat = -33.5, zoom = 5) %>%

  # ── Couche : Toutes les affaires ──────────────────────────────────
  addCircleMarkers(
    data        = cas_geo,
    lng         = ~lng_j,
    lat         = ~lat_j,
    radius      = ~rayon,
    fillColor   = ~couleur,
    color       = "rgba(255,255,255,0.35)",
    weight      = 1.5,
    fillOpacity = 0.75,
    popup       = ~popup_html,
    popupOptions = popupOptions(
      maxWidth  = 320,
      className = "custom-popup"
    ),
    group       = "Toutes les affaires",
    label       = ~paste0(affaire, " (", montant_eur_fmt, ")"),
    labelOptions = labelOptions(
      style     = list(
        "background"   = "#12121a",
        "color"        = "#e8e8f0",
        "border"       = "1px solid #2a2a3a",
        "border-radius"= "4px",
        "font-family"  = "monospace",
        "font-size"    = "11px",
        "padding"      = "4px 8px"
      ),
      noHide    = FALSE,
      direction = "top"
    )
  ) %>%

  # ── Couche : Droite uniquement ────────────────────────────────────
  addCircleMarkers(
    data        = cas_geo %>% filter(bord == "Droite"),
    lng         = ~lng_j, lat = ~lat_j,
    radius      = ~rayon,
    fillColor   = "#e74c3c", color = "white", weight = 1.5, fillOpacity = 0.8,
    popup       = ~popup_html,
    group       = "Droite",
    label       = ~paste0(affaire, " (", montant_eur_fmt, ")")
  ) %>%

  # ── Couche : Gauche uniquement ────────────────────────────────────
  addCircleMarkers(
