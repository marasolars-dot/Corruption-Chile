<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --surface2: #1a1a26;
    --border: #2a2a3a;
    --accent: #ff3c3c;
    --accent2: #ffaa00;
    --accent3: #00d4aa;
    --text: #e8e8f0;
    --muted: #6b6b8a;
    --font-display: 'Syne', sans-serif;
    --font-mono: 'Space Mono', monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--bg); color: var(--text); font-family: var(--font-mono); overflow: hidden; height: 100vh; }

  #map { width: 100vw; height: 100vh; }

  /* HEADER */
  #header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: linear-gradient(180deg, rgba(10,10,15,0.98) 0%, rgba(10,10,15,0) 100%);
    padding: 16px 24px 40px;
    pointer-events: none;
  }
  #header h1 {
    font-family: var(--font-display);
    font-size: clamp(18px, 3vw, 28px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  #header h1 span { color: var(--accent); }
  #header p {
    font-size: 10px;
    color: var(--muted);
    margin-top: 4px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* SIDEBAR */
  #sidebar {
    position: fixed; top: 0; right: 0; bottom: 0; z-index: 1001;
    width: 300px;
    background: var(--surface);
    border-left: 1px solid var(--border);
    display: flex; flex-direction: column;
    transition: transform 0.3s ease;
    overflow: hidden;
  }
  #sidebar.collapsed { transform: translateX(270px); }
  #sidebar-toggle {
    position: absolute; left: -36px; top: 50%;
    transform: translateY(-50%);
    background: var(--surface2);
    border: 1px solid var(--border);
    border-right: none;
    color: var(--text);
    padding: 12px 8px;
    cursor: pointer;
    font-size: 14px;
    border-radius: 6px 0 0 6px;
    writing-mode: vertical-lr;
    letter-spacing: 0.1em;
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
  }
  #sidebar-content { padding: 70px 16px 16px; overflow-y: auto; flex: 1; }
  .sidebar-section { margin-bottom: 20px; }
  .sidebar-label {
    font-size: 9px; text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--muted); margin-bottom: 8px; display: block;
  }
  .filter-group { display: flex; flex-direction: column; gap: 4px; }
  .filter-btn {
    background: var(--surface2); border: 1px solid var(--border);
    color: var(--text); padding: 6px 10px; cursor: pointer;
    font-family: var(--font-mono); font-size: 10px;
    text-align: left; border-radius: 4px; transition: all 0.2s;
    display: flex; justify-content: space-between; align-items: center;
  }
  .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-btn.active { background: var(--accent); border-color: var(--accent); color: white; }
  .filter-btn .count {
    background: rgba(255,255,255,0.15); padding: 2px 6px;
    border-radius: 10px; font-size: 9px;
  }

  /* STATS */
  #stats-bar {
    position: fixed; bottom: 0; left: 0; z-index: 1001;
    background: rgba(10,10,15,0.96);
    border-top: 1px solid var(--border);
    border-right: 1px solid var(--border);
    padding: 10px 20px;
    display: flex; gap: 24px;
    font-size: 10px;
  }
  .stat { display: flex; flex-direction: column; }
  .stat-val {
    font-family: var(--font-display);
    font-size: 18px; font-weight: 800; color: var(--accent);
    line-height: 1;
  }
  .stat-val.green { color: var(--accent3); }
  .stat-val.yellow { color: var(--accent2); }
  .stat-lbl { color: var(--muted); font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 2px; }

  /* LEGEND */
  #legend {
    position: fixed; bottom: 80px; left: 20px; z-index: 1001;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 9px;
    max-width: 200px;
  }
  #legend h4 { font-family: var(--font-display); font-size: 10px; margin-bottom: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; }
  .legend-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .legend-circle {
    border-radius: 50%; border: 2px solid rgba(255,255,255,0.3);
    flex-shrink: 0;
  }
  .leg-sm { width: 10px; height: 10px; background: rgba(255,60,60,0.5); }
  .leg-md { width: 16px; height: 16px; background: rgba(255,60,60,0.6); }
  .leg-lg { width: 24px; height: 24px; background: rgba(255,60,60,0.7); }
  .leg-xl { width: 34px; height: 34px; background: rgba(255,60,60,0.8); }
  .legend-color-row { display: flex; gap: 6px; margin-top: 10px; flex-wrap: wrap; }
  .color-chip { display: flex; align-items: center; gap: 4px; }
  .color-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

  /* POPUP */
  .leaflet-popup-content-wrapper {
    background: var(--surface) !important;
    border: 1px solid var(--border) !important;
    border-radius: 8px !important;
    box-shadow: 0 20px 60px rgba(0,0,0,0.8) !important;
    padding: 0 !important;
  }
  .leaflet-popup-tip { background: var(--surface) !important; }
  .leaflet-popup-content { margin: 0 !important; width: 280px !important; }
  .popup-inner { padding: 16px; }
  .popup-year {
    font-size: 9px; text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--muted); margin-bottom: 4px;
  }
  .popup-title {
    font-family: var(--font-display); font-size: 15px; font-weight: 800;
    color: var(--text); margin-bottom: 8px; line-height: 1.2;
  }
  .popup-amount {
    font-family: var(--font-display); font-size: 22px; font-weight: 800;
    color: var(--accent); margin-bottom: 10px;
  }
  .popup-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 10px; }
  .popup-tag {
    background: var(--surface2); border: 1px solid var(--border);
    padding: 2px 8px; border-radius: 10px; font-size: 9px;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .popup-tag.sector { border-color: var(--accent2); color: var(--accent2); }
  .popup-tag.partido { border-color: var(--accent3); color: var(--accent3); }
  .popup-detail { font-size: 10px; color: var(--muted); line-height: 1.6; margin-bottom: 8px; }
  .popup-status {
    background: var(--surface2); padding: 6px 10px;
    border-radius: 4px; font-size: 9px; border-left: 3px solid var(--accent);
    margin-top: 6px;
  }

  /* YEAR SLIDER */
  #year-filter { margin-bottom: 12px; }
  input[type=range] {
    width: 100%; accent-color: var(--accent);
  }
  .year-labels { display: flex; justify-content: space-between; font-size: 9px; color: var(--muted); }

  /* SEARCH */
  #search-input {
    width: 100%; background: var(--surface2); border: 1px solid var(--border);
    color: var(--text); padding: 8px 10px; font-family: var(--font-mono);
    font-size: 10px; border-radius: 4px; outline: none;
    transition: border-color 0.2s;
  }
  #search-input:focus { border-color: var(--accent); }
  #search-input::placeholder { color: var(--muted); }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--surface); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* Info banner */
  #info-banner {
    position: fixed; top: 70px; left: 20px; z-index: 1001;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    padding: 8px 12px;
    font-size: 9px; color: var(--muted);
    border-radius: 4px;
    max-width: 220px;
    transition: opacity 0.3s;
  }
  #info-banner strong { color: var(--text); display: block; margin-bottom: 2px; font-size: 10px; }

  @media (max-width: 600px) {
    #sidebar { width: 260px; }
    #sidebar.collapsed { transform: translateX(235px); }
  }
</style>
</head>
