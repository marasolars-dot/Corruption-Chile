let activeSector = "todos";
let activeTipo = "todos";
let activeEstado = "todos";
let markers = [];
let layerGroup;
let sidebarOpen = true;

const map = L.map('map', {
  center: [-33.5, -70.6],
  zoom: 5,
  zoomControl: true,
  attributionControl: false
});

L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  attribution: '©OpenStreetMap ©CartoDB'
}).addTo(map);

layerGroup = L.layerGroup().addTo(map);

function formatMonto(m) {
  if (!m) return "Desconocido";
  const mm = m / 1000000;
  if (mm >= 1000) return `$${(mm/1000).toFixed(1)} mil mill.`;
  return `$${Math.round(mm).toLocaleString('es-CL')} mill.`;
}

function getRadius(monto) {
  if (!monto) return 6;
  const m = monto / 1000000;
  if (m < 50) return 6;
  if (m < 500) return 10;
  if (m < 2000) return 16;
  if (m < 15000) return 24;
  if (m < 50000) return 36;
  return 48;
}

function getSectorColor(sector) {
  const colors = {
    "Derecha": "#e74c3c",
    "Izquierda": "#3498db",
    "Centro": "#f39c12",
    "Ninguno": "#9b59b6",
    "NA": "#7f8c8d"
  };
  return colors[sector] || "#7f8c8d";
}

function renderMarkers(data) {
  layerGroup.clearLayers();
  markers = [];

  const groups = {};
  data.forEach(c => {
    if (!c.comuna || !COORDS[c.comuna]) return;
    if (!groups[c.comuna]) groups[c.comuna] = [];
    groups[c.comuna].push(c);
  });

  Object.entries(groups).forEach(([comuna, group]) => {
    group.forEach((c, i) => {
      const base = COORDS[c.comuna];
      const angle = (i / group.length) * 2 * Math.PI;
      const jitter = group.length > 1 ? 0.02 + i * 0.01 : 0;
      const lat = base[0] + Math.sin(angle) * jitter;
      const lng = base[1] + Math.cos(angle) * jitter;

      const color = getSectorColor(c.sector);
      const r = getRadius(c.monto);

      const marker = L.circleMarker([lat, lng], {
        radius: r,
        fillColor: color,
        color: 'rgba(255,255,255,0.4)',
        weight: 1.5,
        fillOpacity: 0.75
      });

      marker.bindPopup(buildPopup(c), { maxWidth: 300, className: 'dark-popup' });

      marker.on('mouseover', function() {
        this.setStyle({ fillOpacity: 1, weight: 2.5, color: 'white' });
      });
      marker.on('mouseout', function() {
        this.setStyle({ fillOpacity: 0.75, weight: 1.5, color: 'rgba(255,255,255,0.4)' });
      });

      layerGroup.addLayer(marker);
      markers.push({ marker, data: c });
    });
  });
}

function buildPopup(c) {
  const sectorBadge = c.sector && c.sector !== "NA" ? `<span class="popup-tag sector">${c.sector}</span>` : '';
  const partidoBadge = c.partido && c.partido !== "NA" ? `<span class="popup-tag partido">${c.partido}</span>` : '';
  const delitos = c.delitos ? `<div class="popup-detail"><strong style="color:var(--text)">Delitos:</strong><br>${c.delitos}</div>` : '';
  const resp = (c.responsable && c.responsable !== "NA") ? `<div class="popup-detail"><strong style="color:var(--text)">Responsable:</strong> ${c.responsable}</div>` : '';
  const posicion = (c.posicion && c.posicion !== "NA") ? `<span class="popup-tag">${c.posicion}</span>` : '';
  const status = c.conclusion ? `<div class="popup-status">⚖️ ${c.conclusion}</div>` : (c.estado ? `<div class="popup-status">🔍 ${c.estado}</div>` : '');

  return `<div class="popup-inner">
    <div class="popup-year">📅 ${c.año} · ${c.comuna || 'Nivel nacional'}</div>
    <div class="popup-title">${c.caso}</div>
    <div class="popup-amount">${formatMonto(c.monto)}</div>
    <div class="popup-tags">${sectorBadge}${partidoBadge}${posicion}</div>
    ${resp}
    ${delitos}
    ${status}
  </div>`;
}

function applyFilters() {
  const search = document.getElementById('search-input').value.toLowerCase();
  const yearMin = parseInt(document.getElementById('year-min').value);
  const yearMax = parseInt(document.getElementById('year-max').value);

  const filtered = casos.filter(c => {
    if (c.año < Math.min(yearMin, yearMax) || c.año > Math.max(yearMin, yearMax)) return false;
    if (search) {
      const hay = `${c.caso} ${c.responsable} ${c.comuna} ${c.sector} ${c.partido} ${c.delitos || ''}`.toLowerCase();
      if (!hay.includes(search)) return false;
    }
    if (activeSector !== 'todos' && c.sector !== activeSector) return false;
    if (activeTipo === 'fundaciones' && c.posicion !== 'Fundación') return false;
    if (activeTipo === 'alcaldias' && c.posicion !== 'Alcalde') return false;
    if (activeTipo === 'ffaa' && !['Carabineros', 'Ejército', 'PDI', 'Policía de Investigaciones'].includes(c.posicion)) return false;
    if (activeEstado !== 'todos' && c.estado !== activeEstado && c.conclusion !== activeEstado) return false;
    return true;
  });

  renderMarkers(filtered);
  updateStats(filtered);
}

function updateStats(data) {
  const validData = data.filter(c => COORDS[c.comuna]);
  const total = validData.reduce((s, c) => s + (c.monto || 0), 0);
  const comunas = new Set(validData.map(c => c.comuna).filter(Boolean)).size;
  document.getElementById('stat-casos').textContent = validData.length;
  document.getElementById('stat-monto').textContent = formatMonto(total);
  document.getElementById('stat-comunas').textContent = comunas;
}

function updateYearDisplay() {
  document.getElementById('year-min-label').textContent = document.getElementById('year-min').value;
  document.getElementById('year-max-label').textContent = document.getElementById('year-max').value;
}

const sectors = ["todos", "Derecha", "Izquierda", "Centro", "Ninguno"];
const sectorLabels = { todos: "Todos", Derecha: "Derecha", Izquierda: "Izquierda", Centro: "Centro", Ninguno: "Sin partido" };
const sectorColors = { todos: "#fff", Derecha: "#e74c3c", Izquierda: "#3498db", Centro: "#f39c12", Ninguno: "#9b59b6" };

function buildSectorFilters() {
  const container = document.getElementById('sector-filters');
  sectors.forEach(s => {
    const cnt = s === 'todos' ? casos.length : casos.filter(c => c.sector === s).length;
    const btn = document.createElement('button');
    btn.className = 'filter-btn' + (s === 'todos' ? ' active' : '');
    btn.innerHTML = `<span style="display:flex;align-items:center;gap:6px"><span style="width:8px;height:8px;border-radius:50%;background:${sectorColors[s]};flex-shrink:0"></span>${sectorLabels[s]}</span><span class="count">${cnt}</span>`;
    btn.onclick = () => {
      document.querySelectorAll('#sector-filters .filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeSector = s;
      applyFilters();
    };
    container.appendChild(btn);
  });
}

function selectTipo(btn, tipo) {
  document.querySelectorAll('#tipo-filters .filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  activeTipo = tipo;
  applyFilters();
}

function buildEstadoFilters() {
  const container = document.getElementById('estado-filters');
  const estados = ["todos", "En investigación", "Prisión preventiva", "Condenado", "condena", "impunidad"];
  const labels = { todos: "Todos", "En investigación": "En investigación", "Prisión preventiva": "Prisión preventiva", "Condenado": "Condenado", "condena": "Condena firme", "impunidad": "Impunidad" };
  estados.forEach(e => {
    const cnt = e === 'todos' ? casos.length : casos.filter(c => c.estado === e || c.conclusion === e).length;
    if (cnt === 0 && e !== 'todos') return;
    const btn = document.createElement('button');
    btn.className = 'filter-btn' + (e === 'todos' ? ' active' : '');
    btn.innerHTML = `${labels[e]}<span class="count">${cnt}</span>`;
    btn.onclick = () => {
      document.querySelectorAll('#estado-filters .filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeEstado = e;
      applyFilters();
    };
    container.appendChild(btn);
  });
}

function updateTipoCounts() {
  document.getElementById('cnt-todos').textContent = casos.length;
  document.getElementById('cnt-fundaciones').textContent = casos.filter(c=>c.posicion==='Fundación').length;
  document.getElementById('cnt-alcaldias').textContent = casos.filter(c=>c.posicion==='Alcalde').length;
  document.getElementById('cnt-ffaa').textContent = casos.filter(c=>['Carabineros','Ejército','PDI','Policía de Investigaciones'].includes(c.posicion)).length;
}

function toggleSidebar() {
  const sb = document.getElementById('sidebar');
  sidebarOpen = !sidebarOpen;
  sb.classList.toggle('collapsed', !sidebarOpen);
  document.getElementById('sidebar-toggle').textContent = sidebarOpen ? 'FILTROS ▶' : '◀ FILTROS';
}

buildSectorFilters();
buildEstadoFilters();
updateTipoCounts();
applyFilters();

setTimeout(() => {
  const b = document.getElementById('info-banner');
  b.style.opacity = '0';
  setTimeout(() => b.style.display = 'none', 300);
}, 5000);
</script>
